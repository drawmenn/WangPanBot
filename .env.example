# =========================
# Required for all providers
# =========================
BOT_TOKEN=123456:your_telegram_bot_token

# Enable MTProto large-file web downloads (>20MB in browser)
# Get API_ID/API_HASH from https://my.telegram.org
API_ID=
API_HASH=
MTPROTO_DOWNLOAD_ENABLED=1

# Optional: admin Telegram user id (for delete/manage permissions)
# Fill with Telegram numeric user id, e.g. 123456789
# Leave empty to disable admin-only actions
ADMIN_ID=

# Search settings
SEARCH_LIMIT=5
SEARCH_SESSION_TTL_SECONDS=1800

# =========================
# Database provider selector
# Options: sqlite | supabase | mongodb | turso | neon
# =========================
DB_PROVIDER=sqlite

# --- sqlite (local file) ---
DB_PATH=data.db

# --- supabase (Postgres) ---
# Use one of the connection strings from Supabase "Connect" page.
# Prefer session/direct connection strings for long-running services.
SUPABASE_DATABASE_URL=
SUPABASE_DB_URL=

# --- neon (Postgres) ---
NEON_DATABASE_URL=

# --- shared fallback for postgres providers ---
# If set, supabase/neon can also read from DATABASE_URL.
DATABASE_URL=
POSTGRES_POOL_SIZE=5

# --- mongodb atlas ---
MONGODB_URI=
# Optional. If empty, driver tries URI default database, then "wangpanbot".
MONGODB_DB_NAME=
MONGODB_COLLECTION_NAME=files

# --- turso (libSQL) ---
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Optional embedded replica path (local file synced with Turso)
TURSO_LOCAL_PATH=

# =========================
# Webhook settings
# Polling mode does not need webhook vars.
# Webhook mode uses one of:
# 1) WEBHOOK_URL
# 2) WEBHOOK_BASE_URL + WEBHOOK_PATH
# 3) RENDER_EXTERNAL_URL (provided automatically on Render)
# =========================
# Set to 0 on standby instances to prevent webhook takeover.
WEBHOOK_ENABLED=1
# Keep 0 on Render/free sleeping hosts so Telegram can wake the service.
WEBHOOK_DELETE_ON_SHUTDOWN=0
WEBHOOK_PATH=/webhook
WEBHOOK_URL=
WEBHOOK_BASE_URL=https://your-domain.com

# =========================
# Optional web drive page
# =========================
# 1 to enable /drive page, 0 to disable
WEB_UI_ENABLED=1
# Optional admin token for web delete API
# If empty, web page stays read-only for delete actions
WEB_ADMIN_TOKEN=
# Optional upload target chat id for web upload
# If empty, upload falls back to ADMIN_ID
WEB_UPLOAD_CHAT_ID=
