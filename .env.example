BOT_TOKEN=123456:your_telegram_bot_token
ADMIN_ID=
DB_PATH=data.db
SEARCH_LIMIT=5

# Polling mode does not need webhook vars.
# Webhook mode: set either WEBHOOK_URL or WEBHOOK_BASE_URL.
# On Render web service, RENDER_EXTERNAL_URL is provided automatically.
WEBHOOK_PATH=/webhook
WEBHOOK_URL=
WEBHOOK_BASE_URL=https://your-domain.com
